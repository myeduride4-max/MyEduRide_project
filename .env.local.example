# Supabase (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend (https://resend.com)
RESEND_API_KEY=your_resend_api_key

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Super admins (comma-separated — also used by npm run seed:admin)
SUPER_ADMIN_EMAILS=admin1@example.com,admin2@example.com
# Optional: platform school row for super_admin roles (default UUID below)
# PLATFORM_SCHOOL_ID=00000000-0000-0000-0000-000000000001
# PLATFORM_SCHOOL_NAME=MyEduRide Platform
